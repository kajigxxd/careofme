{
  "name": "careofme",
  "version": "1.2.0",
  "description": "careofme — Telegram Mini App + bot for mental wellbeing (RU)",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "tunnel": "npx --yes cloudflared tunnel --protocol http2 --url http://127.0.0.1:8787"
  },
  "keywords": [
    "telegram",
    "mini-app",
    "mental-health",
    "careofme",
    "bot"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "grammy": "^1.35.0",
    "openai": "^4.86.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
