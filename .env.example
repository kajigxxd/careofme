# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# SpaceXAI / xAI — для AI-коуча (https://console.x.ai)
XAI_API_KEY=

# Модель (по умолчанию grok-4.5)
XAI_MODEL=grok-4.5

# Путь к JSON-хранилищу (по умолчанию ./data/store.json)
DATA_PATH=./data/store.json

# HTTP-порт Mini App + API
PORT=8787

# Публичный HTTPS URL Mini App (cloudflared / ngrok / Vercel)
# Пример: https://xxxx.trycloudflare.com
WEBAPP_URL=

# Только для локального превью в браузере без Telegram (не для прода)
# WEBAPP_DEV_SKIP_AUTH=1

# Telegram Crypto Pay (@CryptoBot → Crypto Pay → Create App)
# https://t.me/CryptoBot?start=pay
CRYPTO_PAY_TOKEN=
# CRYPTO_PAY_TESTNET=1

# Демо-активация тарифа без оплаты (только dev)
# ALLOW_DEMO_PAY=1

# Webhook mode (production)
# USE_WEBHOOK=1
